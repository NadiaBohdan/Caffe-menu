{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",
    "checkJs": true,
    "baseUrl": ".",
    "paths": {
      "#configs/*": ["./src/configs/*"],
      "#middlewares/*": ["./src/middlewares/*"],
      "#user/*": ["./src/modules/user/*"],
      "#auth/*": ["./src/modules/auth/*"],
      "#table/*": ["./src/modules/table/*"],
      "#utils/*": ["./src/utils/*"]
    }
  },
  "exclude": ["node_modules"]
}