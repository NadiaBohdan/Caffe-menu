generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  courier
  employee
}

enum OrderStatus {
  pending
  processing
  completed
  cancelled
}

enum TransactionStatus {
  pending
  confirm
  declined
}

enum PayType {
  cash
  card
}

enum OrderType {
  inCafe
  Pickup
  Delivery
}

enum ContactType {
  phoneNumber
  email
  instagram
  facebook
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  password    String   @db.VarChar(60)
  email       String   @unique
  phoneNumber String   @unique @map("phone_number") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  favourites   Favourite[]
  carts        Cart[]
  orders       Order[]
  transactions Transaction[]

  @@map("user")
}

model Staff {
  id        Int      @id @default(autoincrement())
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  login     String   @unique
  password  String   @db.VarChar(60)
  role      Role
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("staff")
}

model CafeTable {
  id          Int      @id @default(autoincrement())
  tableNumber Int      @map("table_number")
  isAvailable Boolean  @default(true) @map("is_available")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("cafe_table")
}

model Category {
  id        Int       @id @default(autoincrement())
  title     String    @unique
  sortOrder Int       @map("sort_order")
  updatedAt DateTime  @updatedAt @map("updated_at")
  products  Product[]

  @@map("category")
}

model Product {
  id              Int      @id @default(autoincrement())
  title           String
  description     String   @db.Text
  price           Decimal  @db.Decimal(10, 2)
  imgPath         String?  @map("img_path")
  percentDiscount Int      @default(0) @map("percent_discount")
  isAvailable     Boolean  @default(true) @map("is_available")
  updatedAt       DateTime @updatedAt @map("updated_at")

  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], map: "fk_product_category")

  orderItems     OrderItems[]
  favouriteItems FavouriteItems[]
  cartItems      CartItems[]

  @@index([categoryId])
  @@map("product")
}

model Favourite {
  id     Int @id @default(autoincrement())
  userId Int

  user User @relation(fields: [userId], references: [id], map: "fk_favorite_user")

  favouriteItems FavouriteItems[]

  @@unique([userId])
  @@map("favourite")
}

model FavouriteItems {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  favouriteId Int      @map("favourite_id")
  addedAt     DateTime @default(now()) @map("added_at")

  product   Product   @relation(fields: [productId], references: [id], map: "fk_favouriteItems_product", onDelete: Cascade)
  favourite Favourite @relation(fields: [favouriteId], references: [id], map: "fk_favouriteItems_favourite", onDelete: Cascade)

  @@unique([favouriteId, productId])
  @@map("favourite_items")
}

model Cart {
  id     Int @id @default(autoincrement())
  userId Int

  user User @relation(fields: [userId], references: [id], map: "fk_cart_user")

  cartItems CartItems[]

  @@unique([userId])
  @@map("cart")
}

model CartItems {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  productId Int      @map("product_id")
  cartId    Int      @map("cart_id")
  addedAt   DateTime @default(now()) @map("added_at")

  product Product @relation(fields: [productId], references: [id], map: "fk_cartItems_product", onDelete: Cascade)
  cart    Cart    @relation(fields: [cartId], references: [id], map: "fk_cartItems_cart", onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  id          Int       @id @default(autoincrement())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  peopleCount Int       @map("people_count")
  details     String    @default("")
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  readyAt     DateTime  @map("ready_at")
  address     String?
  orderType   OrderType @map("order_type")

  status  OrderStatus @default(pending)
  userId  Int         @map("user_id")
  tableId Int?        @map("table_id")
  staffId Int?        @map("staff_id")

  user  User       @relation(fields: [userId], references: [id], map: "fk_order_user")
  table CafeTable? @relation(fields: [tableId], references: [id], map: "fk_order_table")
  staff Staff?     @relation(fields: [staffId], references: [id], map: "fk_order_staff")

  orderItems   OrderItems[]
  transactions Transaction[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([staffId])
  @@map("order")
}

model OrderItems {
  id              Int     @id @default(autoincrement())
  quantity        Int     @default(1)
  priceAtPurchase Decimal @map("price_at_purchase") @db.Decimal(10, 2)
  orderId         Int     @map("order_id")
  productId       Int     @map("product_id")

  order   Order   @relation(fields: [orderId], references: [id], map: "fk_orderItems_order")
  product Product @relation(fields: [productId], references: [id], map: "fk_orderItems_product")

  @@unique([orderId, productId])
  @@map("order_items")
}

model Transaction {
  id        Int               @id @default(autoincrement())
  status    TransactionStatus @default(pending)
  payType   PayType           @map("pay_type")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  orderId   Int               @map("order_id")
  userId    Int               @map("user_id")

  order Order @relation(fields: [orderId], references: [id], map: "fk_transactions_order")
  user  User  @relation(fields: [userId], references: [id], map: "fk_transactions_user")

  @@index([userId])
  @@index([orderId])
  @@map("transactions")
}

model Contact {
  id  Int @id @default(autoincrement())
  name ContactType
  link String

  @@map("contact")
}