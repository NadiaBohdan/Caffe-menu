generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  engineType    = "library"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  admin
  employee
}

enum Status {
  pending
  processing
  completed
}

model User {
  id          Int      @id @default(autoincrement())
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  password    String   @db.VarChar(60)
  email       String   @unique
  phoneNumber String   @unique @map("phone_number") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  role        Role     @default(user)

  favourites Favourite[]
  carts      Cart[]
  orders     Order[]

  @@map("user")
}

model CafeTable {
  id          Int     @id @default(autoincrement())
  tableNumber Int     @unique @map("table_number")
  isAvailable Boolean @default(true) @map("is_available")

  orders Order[]

  @@map("cafe_table")
}

model Category {
  id        Int       @id @default(autoincrement())
  title     String
  sortOrder Int @map("sort_order")
  products  Product[]

  @@map("category")
}

model Product {
  id              Int     @id @default(autoincrement())
  title           String
  description     String  @db.Text
  price           Decimal @db.Decimal(10, 2)
  imgPath         String? @map("img_path")
  percentDiscount Int?    @map("percent_discount")
  isAvailable     Boolean @default(true) @map("is_available")

  categoryId Int      @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id], map: "fk_product_category")

  favourites Favourite[]
  carts      Cart[]
  orderItems OrderItems[]

  @@index([categoryId])
  @@map("product")
}

model Favourite {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  userId    Int      @map("user_id")
  addedAt   DateTime @default(now()) @map("added_at")

  product Product @relation(fields: [productId], references: [id], map: "fk_favourite_product")
  user    User    @relation(fields: [userId], references: [id], map: "fk_favourite_user")

  @@unique([userId, productId])
  @@map("favourite")
}

model Cart {
  id        Int      @id @default(autoincrement())
  quantity  Int      @default(1)
  productId Int      @map("product_id")
  userId    Int      @map("user_id")
  addedAt   DateTime @default(now()) @map("added_at")

  product Product @relation(fields: [productId], references: [id], map: "fk_cart_product")
  user    User    @relation(fields: [userId], references: [id], map: "fk_cart_user")

  @@unique([userId, productId])
  @@map("cart")
}

model Order {
  id         Int      @id @default(autoincrement())
  createdAt  DateTime @default(now()) @map("created_at")
  pickupTime DateTime @map("pickup_time")
  isInCafe   Boolean  @map("is_in_cafe")
  status     Status   @default(pending)
  userId     Int      @map("user_id")
  tableId    Int?     @map("table_id")

  user  User       @relation(fields: [userId], references: [id], map: "fk_order_user")
  table CafeTable? @relation(fields: [tableId], references: [id], map: "fk_order_table")

  orderItems OrderItems[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@map("order")
}

model OrderItems {
  id              Int     @id @default(autoincrement())
  quantity        Int     @default(1)
  priceAtPurchase Decimal @map("price_at_purchase") @db.Decimal(10, 2)
  orderId         Int     @map("order_id")
  productId       Int     @map("product_id")

  order   Order   @relation(fields: [orderId], references: [id], map: "fk_orderItems_order")
  product Product @relation(fields: [productId], references: [id], map: "fk_orderItems_product")

  @@unique([orderId, productId])
  @@map("order_items")
}
